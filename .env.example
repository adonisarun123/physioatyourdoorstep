# ---------------------------------------------------------------------------
# Physio At Your Doorstep — environment variables
# Copy to .env (or set in your hosting dashboard) and fill in real values.
# ---------------------------------------------------------------------------
#
# There is NO database. Booking and contact submissions are delivered purely
# as email, so the SMTP settings below are REQUIRED — without them both forms
# will tell the user the submission failed.
#
# Site content (services, locations, blogs) is file-based under /content and
# /markdown, so nothing else needs configuring to run the site.
# ---------------------------------------------------------------------------

# REQUIRED — the Gmail address used to SEND notifications.
GMAIL_USER=

# REQUIRED — a Google "App Password" for that Gmail account, NOT the account
# password. Requires 2-Step Verification: Google Account → Security →
# 2-Step Verification → App passwords → create one for "Mail".
# Paste the 16-character password WITHOUT spaces.
GMAIL_APP_PASSWORD=

# OPTIONAL — where notifications are delivered. Defaults to GMAIL_USER.
NOTIFICATION_EMAIL=

# OPTIONAL — BCC on every notification. Defaults to arun@monkmantra.com.
NOTIFICATION_BCC=

# OPTIONAL — generic SMTP names are accepted as aliases for the Gmail vars
# above, so switching providers doesn't require code changes:
#   SMTP_USER / SMTP_PASS  (aliases for GMAIL_USER / GMAIL_APP_PASSWORD)
#   SMTP_HOST              (default: smtp.gmail.com)
#   SMTP_PORT              (default: 465 — implicit TLS; use 587 for STARTTLS)
SMTP_HOST=
SMTP_PORT=

# OPTIONAL — secret for GET /api/email-health?key=<value>, which verifies the
# SMTP login in production without sending mail. Endpoint 404s if unset.
# Since submissions are email-only, this is the fastest way to confirm the
# forms are working after a deploy or an env-var change.
EMAIL_DIAG_KEY=

# OPTIONAL — Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# If unset, analytics is simply disabled (safe for dev/staging).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
