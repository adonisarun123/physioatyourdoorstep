# ---------------------------------------------------------------------------
# Physio At Your Doorstep — environment variables
# Copy to .env (or set in Railway) and fill in real values before go-live.
# ---------------------------------------------------------------------------

# REQUIRED for the booking & contact forms to save submissions.
# Without this, both forms will show an error to the user.
# MySQL connection string, e.g. mysql://user:password@host:3306/dbname
DATABASE_URL=

# OPTIONAL — Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# If unset, analytics is simply disabled (safe for dev/staging).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Email notifications (booking + contact forms) via Gmail SMTP.
# If unset, forms still work — submissions are saved to the database, but no
# notification email is sent (a warning is logged instead).
# On Vercel: Project → Settings → Environment Variables, then redeploy.
# ---------------------------------------------------------------------------

# The Gmail address used to SEND notifications.
GMAIL_USER=

# A Google "App Password" for that Gmail account — NOT the account password.
# Requires 2-Step Verification: Google Account → Security →
# 2-Step Verification → App passwords → create one for "Mail".
# Paste the 16-character password WITHOUT spaces.
GMAIL_APP_PASSWORD=

# OPTIONAL — where notifications are delivered. Defaults to GMAIL_USER.
NOTIFICATION_EMAIL=

# OPTIONAL — BCC on every notification. Defaults to arun@monkmantra.com.
NOTIFICATION_BCC=

# OPTIONAL — secret for GET /api/email-health?key=<value>, which verifies the
# SMTP login in production without sending mail. Endpoint 404s if unset.
EMAIL_DIAG_KEY=
